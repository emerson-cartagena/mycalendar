# ─────────────────────────────────────────────────────────────
#  Variables de entorno del FRONTEND (prefijo VITE_)
#  Copia este archivo como .env y rellena los valores reales.
# ─────────────────────────────────────────────────────────────

# Supabase — Project Settings > API
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY

# Cloudflare Turnstile — dash.cloudflare.com > Turnstile > tu sitio > Site key
# En desarrollo se omite automáticamente (no se muestra el widget).
VITE_TURNSTILE_SITE_KEY=TU_SITE_KEY

# ─────────────────────────────────────────────────────────────
#  Secrets de Edge Functions (NO van en este archivo)
#  Configúralos en Supabase con:
#
#  supabase secrets set NOMBRE=valor --project-ref TU_PROJECT_REF
#
#  Secrets necesarios:
#
#  TURNSTILE_SECRET_KEY   — dash.cloudflare.com > Turnstile > tu sitio > Secret key
#  RESEND_API_KEY         — resend.com > API Keys
#
#  SUPABASE_URL, SUPABASE_ANON_KEY y SUPABASE_SERVICE_ROLE_KEY
#  son inyectados automáticamente por Supabase en las Edge Functions.
# ─────────────────────────────────────────────────────────────
